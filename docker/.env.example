#########################
# UNIT3D UPLOAD CHECKER
# Environment Configuration Template
# https://github.com/magrhino/UNIT3D-Upload-Checker
#########################
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your API keys and settings below
# 3. Run setup: docker compose --profile setup run --rm setup
# 4. Start the long-running container: docker compose up -d
#
#########################

########################################
# 🌍 Media Directory Configuration (REQUIRED)
########################################
# HOST_MEDIA_DIR:
#   Absolute path on your host that contains the media you want to scan.
#   Examples:
#     HOST_MEDIA_DIR=/mnt/storage/movies
#     HOST_MEDIA_DIR=./data            # relative to this docker/ folder
#
# CONTAINER_MEDIA_DIR:
#   Path inside the container where the host folder will be mounted.
#   Defaults to /data, but you can change it if needed.
#
# MEDIA_DIR:
#   The path(s) inside the container that the setup script will configure.
#   - For single directory: Use a single CONTAINER path (e.g., /data)
#   - For multiple directories: Use comma-separated CONTAINER paths
#
#   Examples:
#     MEDIA_DIR=/data                              # Single directory
#     MEDIA_DIR=/media/movies,/media/tv            # Multiple directories
#     MEDIA_DIR=/data/movies,/data/tv,/data/anime  # Three directories
#
# IMPORTANT: MEDIA_DIR must use CONTAINER paths (where volumes are mounted),
# not host paths. The default compose file supports one host media root.
# If you have multiple unrelated host roots, add each extra volume mount once
# in docker-compose.yml, then set MEDIA_DIR to comma-separated container paths.

HOST_MEDIA_DIR=/path/to/your/media
CONTAINER_MEDIA_DIR=/data

# Single directory (default)
MEDIA_DIR=/data

# Multiple directories examples (uncomment and edit if needed)
# MEDIA_DIR=/media/movies,/media/tv
# MEDIA_DIR=/data/movies,/data/tv,/data/anime

########################################
# 🎬 TMDB Configuration (REQUIRED)
########################################
# TMDB API key for matching movie metadata
# Get your free API key from: https://www.themoviedb.org/settings/api
# Without this key, the application cannot match movies
TMDB_API_KEY=your_tmdb_api_key_here

########################################
# ✅ Enabled Trackers
########################################
# Comma-separated list of tracker nicknames you want to enable
# Only trackers with valid API keys above will work
#
# Valid nicknames:
#   aith, blu, fnp, lst, oe, rfx, ulcx, ras, hhd
#
# Examples:
#   Single tracker:  SITES_ENABLED=blu
#   Multiple:        SITES_ENABLED=blu,fnp,ras
#   All available:   SITES_ENABLED=aith,blu,fnp,lst,oe,rfx,ulcx,ras,hhd
########################################
SITES_ENABLED=

########################################
# 🎯 Tracker API Keys (OPTIONAL)
########################################
# Add API keys for the trackers you want to use
# Leave blank if you don't have access to a particular tracker
#
# How to get tracker API keys:
# 1. Log into your tracker account
# 2. Go to Settings > Security or Settings > API
# 3. Generate a new API token
# 4. Copy it to the appropriate field below
########################################

# Aither (aith)
AITH_API_KEY=

# Blutopia (blu)
BLU_API_KEY=

# FearNoPeer (fnp)
FNP_API_KEY=

# LST (lst, lstgg)
LST_API_KEY=

# OnlyEncodes (oe)
OE_API_KEY=

# ReelFliX (rfx)
RFX_API_KEY=

# Upload.cx (ulcx)
UPLOADCX_API_KEY=

# Rastastugan (ras)
RAS_API_KEY=

# HomieHelpDesk (hhd)
HHD_API_KEY=

########################################
# 🤖 Optional: Automation Tool Paths
########################################
# Paths to gg-bot and upload-assistant for automated uploads
# Only needed if you're using the export_gg() or export_ua() features
#
# Example paths:
#   GG_PATH=/home/user/gg-bot-upload-assistant/
#   UA_PATH=/home/user/upload-assistant/
#
# Leave blank if not using these tools
########################################
GG_PATH=
UA_PATH=

########################################
# 📝 Notes
########################################
#
# After configuring this file:
# 1. Build the image: docker compose build
# 2. Run the setup script (required once per configuration change):
#      docker compose --profile setup run --rm setup
# 3. Start the container: docker compose up -d
# 4. Access the shell: docker exec -it unit3d-upload-checker bash
# 5. Run the checker: python3 check.py run-all -v
#
########################################
